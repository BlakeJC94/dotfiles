#!usr/bin/env sh
alias ls='ls --color=auto'
alias dir='dir --color=auto'
alias vdir='vdir --color=auto'
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

alias duh='du -d 1 -h'

alias today='vim -c "ThisWeek"'
alias vimpy='vim -c "S uv run ipython"'


alias ip-global='echo "IPv4: $(curl -4 -s https://api.ipify.org)"; echo "IPv6: $(curl -6 -s https://api64.ipify.org)"'
alias ip-local="ip route get 1.1.1.1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if(\$i==\"src\") print \$(i+1)}'"

alias least='bat --paging always --style plain'
alias leastmd='least -l markdown'

alias meminfo='free -m -l -t'
alias psmem='ps auxf | sort -nr -k 4'
alias pscpu='ps auxf | sort -nr -k 3'

alias todo='rg -o --hidden --iglob "!.git" --iglob "!TODO.md" "TODO.*"'

alias vi='command vim'
alias vim='nvim'

alias gcd='cd "$(dirname "$(git rev-parse --absolute-git-dir)")"'

alias d='git dotfiles'
alias l='eza'
alias g='cd $(fd ".git$" ~/Workspace/repos -H -I -d 5 -x dirname {} \; | fzf || echo .)'
alias c='cd "$(find . -maxdepth 1 -type d | fzf || echo .)"'
alias C='cd "$(find . -type d | fzf || echo .)"'
alias q="exit"

alias teety="tee /dev/tty"

alias opencode-resume='opencode --session $(opencode session list --format json | jq -r ".[] | [.title, .id] | @tsv" | fzf --delimiter=$"\t" --with-nth=1 | cut -f2)'

note() {
    vim -c "Note ${1}"
}

# secret() {
#     name=${1:-}
#     rg "${name}" ~/.env | sed 's/.*=//'
# }

pbpaste() {
    if [ -n "${DISPLAY}" ] && which xclip &>/dev/null; then
        xclip -selection c -o
    elif which wl-paste &>/dev/null; then
        wl-paste
    elif which pbpaste &>/dev/null; then
        command pbpaste
    else
        cat /tmp/clipboard
    fi
}

pbcopy() {
    if [ -n "${DISPLAY}" ] && which xclip &>/dev/null; then
        xclip -selection c
    elif which wl-copy &>/dev/null; then
        wl-copy
    elif which pbcopy &>/dev/null; then
        command pbcopy
    else
        cat - > /tmp/clipboard
    fi
}
