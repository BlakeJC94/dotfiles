#!/usr/bin/env bash
set -euo pipefail

SECRETS_FILE="${SECRETS_FILE:-$HOME/.secrets.enc}"

die() { echo "ERROR: $*" >&2; exit 1; }

# ---------- helpers ----------
get_passphrase() {
  local prompt="${1:-Unlock: }"
  local pass
  read -s -p "$prompt" pass
  echo >&2
  [[ -z "$pass" ]] && die "Passphrase must not be empty"
  printf '%s' "$pass"
}

encrypt()   { openssl enc -aes-256-cbc -pbkdf2 -salt -pass "pass:$1"; }
decrypt()   { openssl enc -d -aes-256-cbc -pbkdf2 -salt -pass "pass:$1"; }

# ---------- commands ----------
cmd_init() {
  [[ -f "$SECRETS_FILE" ]] && die "Secrets file already exists: $SECRETS_FILE"

  local p1 p2
  p1="$(get_passphrase 'Set passphrase: ')"
  p2="$(get_passphrase 'Confirm: ')"
  [[ "$p1" != "$p2" ]] && die "Passphrases do not match"

  printf '' | encrypt "$p1" > "$SECRETS_FILE" || die "Init failed"
  echo "Created $SECRETS_FILE"
}

cmd_get() {
  local key="$1"
  [[ -f "$SECRETS_FILE" ]] || die "No secrets file found. Run: secret init"

  local pass; pass="$(get_passphrase 'Unlock: ')"
  local decrypted
  decrypted="$(decrypt "$pass" < "$SECRETS_FILE" 2>/dev/null)" || die "Decryption failed"

  local match
  match="$(printf '%s\n' "$decrypted" | grep "^${key}=" || true)"
  [[ -z "$match" ]] && die "Key not found: $key"
  printf '%s\n' "${match#*=}"
}

cmd_set() {
  local key="$1"
  [[ -f "$SECRETS_FILE" ]] || die "No secrets file found. Run: secret init"
  [[ "$key" =~ "=" ]] && die "Key must not contain '='"

  local pass; pass="$(get_passphrase 'Unlock: ')"

  local tmp_plain; tmp_plain="$(mktemp)"
  trap 'shred -u "$tmp_plain"' EXIT

  decrypt "$pass" < "$SECRETS_FILE" > "$tmp_plain" 2>/dev/null || die "Decryption failed"

  local value
  read -s -p "Enter secret: " value
  echo >&2

  grep -q "^${key}=" "$tmp_plain" && sed -i "/^${key}=/d" "$tmp_plain"
  printf '%s\n' "${key}=${value}" >> "$tmp_plain"

  encrypt "$pass" < "$tmp_plain" > "$SECRETS_FILE" || die "Re-encryption failed"
  shred -u "$tmp_plain"
  trap - EXIT
}

cmd_list() {
  [[ -f "$SECRETS_FILE" ]] || die "No secrets file found. Run: secret init"

  local pass; pass="$(get_passphrase 'Unlock: ')"
  local decrypted
  decrypted="$(decrypt "$pass" < "$SECRETS_FILE" 2>/dev/null)" || die "Decryption failed"

  local keys
  keys="$(printf '%s\n' "$decrypted" | grep -v '^\s*$' | cut -d= -f1)"
  [[ -z "$keys" ]] && echo "No secrets stored" && return 0
  printf '%s\n' "$keys"
}

cmd_remove() {
  local key="$1"
  [[ -f "$SECRETS_FILE" ]] || die "No secrets file found. Run: secret init"

  local pass; pass="$(get_passphrase 'Unlock: ')"

  local tmp_plain; tmp_plain="$(mktemp)"
  trap 'shred -u "$tmp_plain"' EXIT

  decrypt "$pass" < "$SECRETS_FILE" > "$tmp_plain" 2>/dev/null || die "Decryption failed"
  grep -q "^${key}=" "$tmp_plain" || die "Key not found: $key"
  sed -i "/^${key}=/d" "$tmp_plain"

  encrypt "$pass" < "$tmp_plain" > "$SECRETS_FILE" || die "Re-encryption failed"
  shred -u "$tmp_plain"
  trap - EXIT
}

# ---------- main ----------
usage() {
  echo "Usage: secret {init|get <key>|set <key>|remove <key>|list}"
  exit 1
}

for cmd in openssl shred; do
  command -v "$cmd" >/dev/null 2>&1 || die "Required command not found: $cmd"
done

[[ $# -ge 1 ]] || usage
cmd="$1"; shift
case "$cmd" in
  init)   cmd_init ;;
  get)    [[ $# -eq 1 ]] || usage; cmd_get "$1" ;;
  set)    [[ $# -eq 1 ]] || usage; cmd_set "$1" ;;
  remove) [[ $# -eq 1 ]] || usage; cmd_remove "$1" ;;
  list)   cmd_list ;;
  *)      usage ;;
esac
